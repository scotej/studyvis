# Tauri / Rust
src-tauri/target
src-tauri/gen/schemas

# llama-server sidecar artifacts (fetched by scripts/fetch-llama-server.sh).
# Per-platform release pipelines run the script before bundling; the produced
# binaries + companion dylibs/dlls are too large for source control.
src-tauri/binaries/llama-server-*
src-tauri/binaries/llama-runtime-*/

# Agent/tool local scratch (settings.local.json already matches *.local above).
# Worktrees and lock files are per-machine and must never be committed.
.claude/worktrees/
.claude/scheduled_tasks.lock

# Impeccable critique-tool output (local review scratch).
.impeccable/
